{
  "name": "procon-gamepad-mapper",
  "version": "0.1.0",
  "description": "Nintendo Switch Pro Controller action mapper for browser games and web apps.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "build:demo": "vite build --config vite.config.ts",
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "keywords": [
    "gamepad",
    "nintendo-switch",
    "pro-controller",
    "browser",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.0.0",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.0",
    "vitest": "^1.6.0"
  }
}
